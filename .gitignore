studies/runs/
results/remote_sync/
datasets/raw/
datasets/processed/
datasets/synthetic/natural_saturated/
datasets/synthetic/natural_saturated_reordered/
datasets/synthetic/natural_saturated_strong/
datasets/synthetic/recency_trap/
datasets/synthetic/shared_prefix/

# Heavy generated benchmark internals wherever they appear.
**/traces/
**/benchmarks/*.jsonl
**/plans/belady_plan.json

# Local analysis environments.
.venv-analysis/
.venv-plots/
